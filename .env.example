# Server
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Database (Supabase)
# Runtime: pooled transaction-mode (port 6543) — for the app
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations: session-mode pooler (port 5432) — for prisma migrate
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET=development-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=development-session-secret

# CORS — comma-separated list of allowed origins (frontend URLs).
# In dev, Vite proxies /api → backend, so CORS is bypassed. Production must list the real FE origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Encryption (for 2FA secrets) - MUST be 32 hex chars in production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# TOTP
TOTP_ISSUER=Careme

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp BSP
# WHATSAPP_BSP_API_KEY=your_api_key
# WHATSAPP_BSP_WEBHOOK_SECRET=your_webhook_secret

# Supabase project (REST data API + secret key) — for code paths that hit the
# REST API instead of going through Prisma. The publishable key is safe to
# ship to the frontend if needed; the secret key MUST stay server-side only.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co/rest/v1/
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SUPABASE_SECRET_KEY=sb_secret_xxx